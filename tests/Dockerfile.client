# The client test harness image: a real `scripticus` client, installed the way
# a user installs it (pip install the wheels), plus BATS to drive it.
#
# The wheels are the repo's *locally built* packages, not PyPI releases — so
# this image tests the exact working tree, and the pip install exercises the
# real published-artifact install path (not `uv run`). Because the checked-in
# versions are the `0.0.0.dev0` placeholder, the internal same-minor pins can't
# be satisfied from these dev wheels; we drop them to bare names for the build
# (same trick as server/Dockerfile) and install all three wheels together so
# the intra-workspace deps resolve to the wheels present rather than PyPI.
#
# Build context is the repository root:
#   docker build -f tests/Dockerfile.client -t scripticus-client-test .
FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim AS build

WORKDIR /src
COPY . .
RUN sed -i 's/"scripticus-schema[^"]*"/"scripticus-schema"/;s/"scripticus-common[^"]*"/"scripticus-common"/' client/pyproject.toml \
    && sed -i 's/"scripticus-common[^"]*"/"scripticus-common"/' schema/pyproject.toml \
    && uv build --package scripticus-common --wheel --out-dir /wheels \
    && uv build --package scripticus-schema --wheel --out-dir /wheels \
    && uv build --package scripticus --wheel --out-dir /wheels


FROM python:3.12-slim

# bats drives the CLI; curl/ca-certificates for reaching the registry from
# tests; git in case a test authors a package that uses it.
RUN apt-get update \
    && apt-get install -y --no-install-recommends bats curl ca-certificates git \
    && rm -rf /var/lib/apt/lists/*

COPY --from=build /wheels /wheels
RUN pip install --no-cache-dir /wheels/*.whl && rm -rf /wheels

# The repo is mounted read-only at /repo at run time (bats files + fixtures);
# client state must live off it, on a writable path.
ENV SCRIPTICUS_HOME=/state/.scripticus
WORKDIR /repo

CMD ["bats", "--print-output-on-failure", "--recursive", "tests"]
